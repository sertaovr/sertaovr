<svg xmlns="http://www.w3.org/2000/svg" width="600" height="400" viewBox="0 0 600 400">
  <rect width="600" height="400" fill="#8B5E3C"/>
  <rect width="600" height="400" fill="url(#grad)"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#5C3D22;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#A0714A;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Mandacaru estilizado -->
  <g fill="#4A7C59" opacity="0.6">
    <rect x="295" y="160" width="10" height="180" rx="5"/>
    <rect x="260" y="220" width="10" height="80" rx="5"/>
    <rect x="330" y="200" width="10" height="90" rx="5"/>
    <rect x="255" y="210" width="45" height="10" rx="5"/>
    <rect x="330" y="190" width="45" height="10" rx="5"/>
  </g>
  <!-- Sol -->
  <circle cx="100" cy="80" r="40" fill="#E8D5B0" opacity="0.3"/>
  <!-- Texto -->
  <text x="300" y="100" text-anchor="middle" fill="#E8D5B0" font-size="16"
        font-family="Georgia, serif" opacity="0.9">
    SertãoVR
  </text>
  <text x="300" y="124" text-anchor="middle" fill="#C9B483" font-size="12"
        font-family="Arial, sans-serif" opacity="0.7">
    Adicione sua imagem aqui
  </text>
</svg>
